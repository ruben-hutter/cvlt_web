# =============================================================================
# CVLT Web — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git. It is already in .gitignore.
# =============================================================================

# --- Payload CMS ---

# Secret used to sign Payload auth tokens. MUST be unique and random.
# Generate one with: openssl rand -base64 32
PAYLOAD_SECRET=

# SQLite database file path (relative to project root)
DATABASE_URI=file:./db/payload.db

# --- Next.js / Server ---

# Public URL of the site. Used by Payload and Next.js for links, redirects, etc.
# Development: http://localhost:3000
# Staging:     https://dev.cvlt.ch
# Production:  https://cvlt.ch
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Email (Resend) ---

# API key from https://resend.com/api-keys
# Used for transactional emails (membership form confirmation, etc.)
# Leave empty until the membership form feature is built.
RESEND_API_KEY=
