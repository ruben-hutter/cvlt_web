# =============================================================================
# CVLT Web - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git. It is already in .gitignore.
# =============================================================================

# --- Payload CMS ---

# Secret used to sign Payload auth tokens. MUST be unique and random.
# Generate one with: openssl rand -base64 32
PAYLOAD_SECRET=

# SQLite database file path (relative to project root)
DATABASE_URI=file:./db/payload.db

# --- Next.js / Server ---

# Public URL of the site. Used by Payload and Next.js for links, redirects, etc.
# Development: http://localhost:3000
# Staging:     https://dev.cvlt.ch
# Production:  https://cvlt.ch
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Shop / RaiseNow ---
#
# Live RaiseNow paylink URL (example: https://pay.raisenow.io/abcde)
# Required. The shop API fails fast if missing.
SHOP_PAYLINK_URL=
#
# Dedicated secret for shop order token signing (required).
SHOP_ORDER_TOKEN_SECRET=

# --- Email ---

# SMTP credentials for sending emails (membership form, etc.)
SMTP_USER=
SMTP_PASS=

# "From" address for outgoing emails (defaults to SMTP_USER)
SMTP_FROM=

# Recipient for membership form submissions
MEMBERSHIP_EMAIL=

# Recipient for shop order notifications
SHOP_EMAIL=

# Recipient for contact form submissions
CONTACT_EMAIL=
